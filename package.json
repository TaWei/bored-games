{
  "name": "bored-games",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/shared", "server", "client"],
  "scripts": {
    "dev": "bun run --parallel dev:server dev:client",
    "dev:server": "bun --bun --watch run server/src/index.ts",
    "dev:client": "cd client && bun run vite",
    "build": "bun run shared:build && bun run server:build && bun run client:build",
    "shared:build": "cd packages/shared && bun run build",
    "server:build": "cd server && bun run build",
    "client:build": "cd client && bun run build",
    "db:migrate": "cd server && bun run db:migrate",
    "db:studio": "cd server && bunx drizzle-kit studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "rm -rf packages/shared/dist server/dist client/dist"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6"
  }
}
